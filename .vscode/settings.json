{
    // Point to the Python interpreter in your virtual environment
    "python.defaultInterpreterPath": "${workspaceFolder}/.venv/bin/python",
    "ansible.python.interpreterPath": "${workspaceFolder}/.venv/bin/python",
    "ansible.ansible.path": "${workspaceFolder}/.venv/bin/ansible",

    // File associations for Jinja2 templates
    "files.associations": {
        "**/*.j2": "jinja2",
        "**/templates/*.j2": "ansible-jinja"
    },

    // Enable linting and auto-formatting
    "ansible.validation.lint.enabled": true,
    "ansible.validation.enabled": true,
    "yaml.format.enable": true,

    // Recommended for YAML/Ansible readability
    "editor.tabSize": 2,
    "editor.insertSpaces": true
}